# Set to override the dataset path, if you don't want to download from Kaggle.
# e.g. if you have already downloaded the dataset,
#   or if you have a custom dataset you want to use.

# DATASET_PATH_OVERRIDE="path/to/dataset/"



# Set to override the path to the MUSCLE executable, otherwise the Linux version
# will be downloaded from https://github.com/janus-browser/muscle/releases

# MUSCLE_PATH="path/to/muscle-win64.v5.3.exe"
